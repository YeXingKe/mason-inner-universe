APP_ENV=development
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# sqlite | mysql | postgres
DB_DRIVER=sqlite
DB_DSN=storage/miu.db

# MySQL example:
# DB_DRIVER=mysql
# DB_DSN=root:password@tcp(127.0.0.1:3306)/miu?charset=utf8mb4&parseTime=True&loc=Local

# PostgreSQL example:
# DB_DRIVER=postgres
# DB_DSN=host=127.0.0.1 user=postgres password=password dbname=miu port=5432 sslmode=disable
