{
  "name": "mason-inner-universe",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "concurrently -k -n web,server -c blue,green \"npm run dev --prefix web\" \"npm run dev --prefix server\"",
    "dev:web": "npm run dev --prefix web",
    "dev:server": "npm run dev --prefix server",
    "build": "npm run build --prefix web",
    "build:web": "npm run build --prefix web",
    "build:server": "npm run build --prefix server",
    "lint": "npm run lint --prefix web",
    "install:all": "npm install && npm install --prefix web"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
